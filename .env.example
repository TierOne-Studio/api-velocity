# Database Configuration
DATABASE_URL=postgresql://user:password@host:5432/database

# Server Configuration
# NODE_ENV=development
PORT=3000
BASE_URL=https://your-domain.com

# Better Auth Configuration
AUTH_SECRET=your-super-secret-key-change-in-production-min-32-chars

# SQL connection credential encryption (required for saving SQL connections)
# Must be a base64-encoded 32-byte AES-256-GCM key.
PROJECT_SOURCE_SECRET_KEY=replace_with_base64_32_byte_key

# Optional: previous master key for rotation windows. When set, every decrypt
# tries the current key first and falls back to this previous key once. Rows
# successfully decrypted under the previous key are lazily re-encrypted with
# the current key on next read (no batch migration). Once your monitoring
# shows zero "lazy ciphertext upgrade" log lines for a full traffic cycle,
# you can unset PROJECT_SOURCE_SECRET_KEY_PREVIOUS to close the window.
# See docs/sql-connections-key-rotation.md for the full rotation playbook.
# PROJECT_SOURCE_SECRET_KEY_PREVIOUS=

# Note: the chat-to-SQL agent path no longer reads AGENT_FORBIDDEN_DATABASES.
# The host+port forbidden-app-DB guard was removed in favor of an enforced
# read-only contract (SQL validator deny-list, SET TRANSACTION READ ONLY,
# operator-provisioned SELECT-only role grants). See ADR-010 and the
# operator runbook at docs/sql-connections-operations.md.

# Trusted Origins (comma-separated)
TRUSTED_ORIGINS=https://your-frontend.com

# Frontend URL (for email links)
FE_URL=https://your-frontend.com

# Email Configuration (Resend)
RESEND_API_KEY=your_resend_api_key
FROM_EMAIL=noreply@your-domain.com

# Optional test/e2e guardrail for Resend recipients only
# true  -> always enforce delivered@resend.dev / delivered+label@resend.dev style recipients
# false -> disable guardrail even in test mode
ENFORCE_RESEND_TEST_RECIPIENTS=
AIRWEAVE_API_KEY=your_airweave_api_key
# AIRWEAVE_BASE_URL=https://api.airweave.ai
# Defaults to enforced outside production and disabled in production unless set.
# AIRWEAVE_READ_LOCKDOWN_ENFORCE=true

# Organization assigned to newly self-registered users.
# DEFAULT_ORGANIZATION_SLUG=default

# OpenAI / Chat LLM Configuration
# OPENAI_API_KEY is required at startup by the chat and vector embedding
# adapters.
# IMPORTANT: never expose this key to the browser bundle (no VITE_ prefix).
OPENAI_API_KEY=your_openai_api_key

# Default chat model (overridable). See https://developers.openai.com/api/docs/pricing
# OPENAI_MODEL=gpt-5.4-nano

# Chat system prompt overrides (in priority order):
#   1. CHAT_SYSTEM_PROMPT — inline string, highest priority
#   2. CHAT_SYSTEM_PROMPT_PATH — absolute path to a .md file
#   3. (default) src/modules/chat/prompts/expert-persona-system.md, bundled with the build
# CHAT_SYSTEM_PROMPT=
# CHAT_SYSTEM_PROMPT_PATH=

# Chat rate limiting (per user). Defaults: 20 requests / 60_000 ms.
# CHAT_RATE_LIMIT_TTL=60000
# CHAT_RATE_LIMIT_MAX=20

# Chat agent tuning — all knobs are optional and have sensible defaults.
# See docs/chat-tuning-guide.md for detailed explanations of each setting.
# CHAT_AGENT_MAX_ITERATIONS=5
# CHAT_AGENT_TOOL_RESULT_LIMIT=12
# CHAT_AGENT_TOOL_RESULT_CHAR_CAP=3000
# CHAT_AGENT_MAX_SOURCES=15
# CHAT_AGENT_HISTORY_WINDOW=6
# CHAT_AGENT_SEARCH_TIER=classic
# CHAT_AGENT_RETRIEVAL_STRATEGY=

# Optional LLM-backed response-format evaluation tests.
# CHAT_EVALS_ENABLED=false

# Optional fast router. When enabled, high-confidence SQL/RAG questions bypass
# the outer agent's tool-selection step. Low-confidence/invalid classifications
# fall back to the general agent.
# CHAT_ROUTER_ENABLED=false
# CHAT_ROUTER_MODEL=
# CHAT_ROUTER_CONFIDENCE_PCT=70
# CHAT_ROUTING_RULES=
# CHAT_ROUTING_RULES_PATH=
# CHAT_ROUTER_SYSTEM_PROMPT=
# CHAT_ROUTER_SYSTEM_PROMPT_PATH=

# SQL sub-agent safety, cost, and latency controls.
# SQL_AGENT_MODEL=
# SQL_AGENT_MAX_ITERATIONS=8
# SQL_AGENT_STATEMENT_TIMEOUT_MS=5000
# SQL_AGENT_IDLE_TIMEOUT_MS=5000
# SQL_AGENT_CONNECT_TIMEOUT_MS=3000
# SQL_AGENT_MAX_ROWS=200
# SQL_AGENT_MAX_BYTES=65536
# SQL_AGENT_MAX_FIELD_BYTES=4096
# SQL_AGENT_MAX_SQL_LENGTH=8192
# SQL_AGENT_POOL_MAX=2
# SQL_AGENT_SAMPLE_ROWS=
# SQL_AGENT_PREWARM_SCHEMA_ENABLED=false
# SQL_AGENT_DROP_CHECKER_ENABLED=false
# SQL_AGENT_SYSTEM_PROMPT=
# SQL_AGENT_SYSTEM_PROMPT_PATH=
# SQL_TOOL_USAGE_PROMPT=
# SQL_TOOL_USAGE_PROMPT_PATH=
# QUERY_DATABASE_TOOL_DESCRIPTION=
# QUERY_DATABASE_TOOL_DESCRIPTION_PATH=

# Vector DB file storage (required at startup)
S3_BUCKET=your-vector-db-bucket
# S3_REGION=us-east-1
# AWS credentials are resolved through the AWS SDK default credential chain:
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=

# Vector DB ingestion pipeline (required at startup)
# Qdrant Cloud endpoint + API key. The ingestion worker embeds uploaded files
# and upserts vectors into a per-knowledge-base collection. Both are validated
# at boot via validateEnvironment(). Never expose to the browser bundle.
QDRANT_URL=https://your-cluster.qdrant.io:6333
QDRANT_API_KEY=your_qdrant_api_key

# Embedding model + batching knobs (optional; defaults shown).
# EMBEDDING_MODEL must match the dimension of the Qdrant collection; changing it
# after vectors exist requires a new collection (see ADR-014).
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_BATCH_SIZE=96
# EMBEDDING_CONCURRENCY=3
# Minimum cosine similarity percentage for vector-DB chunks. Set 0 to disable.
# VECTOR_DB_MIN_SCORE_PCT=30
