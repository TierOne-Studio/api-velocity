# Database Configuration
DATABASE_URL=postgresql://user:password@host:5432/database

# Server Configuration
PORT=3000
BASE_URL=https://your-domain.com

# Better Auth Configuration
AUTH_SECRET=your-super-secret-key-change-in-production-min-32-chars

# Trusted Origins (comma-separated)
TRUSTED_ORIGINS=https://your-frontend.com

# Frontend URL (for email links)
FE_URL=https://your-frontend.com

# Email Configuration (Resend)
RESEND_API_KEY=your_resend_api_key
FROM_EMAIL=noreply@your-domain.com

# Optional test/e2e guardrail for Resend recipients only
# true  -> always enforce delivered@resend.dev / delivered+label@resend.dev style recipients
# false -> disable guardrail even in test mode
ENFORCE_RESEND_TEST_RECIPIENTS=
AIRWEAVE_API_KEY=your_airweave_api_key

# OpenAI / Chat LLM Configuration
# OPENAI_API_KEY enables natural-language responses in the chat feature.
# When unset, the chat falls back to a raw search-result summary.
# IMPORTANT: never expose this key to the browser bundle (no VITE_ prefix).
OPENAI_API_KEY=your_openai_api_key

# Default chat model (overridable). See https://developers.openai.com/api/docs/pricing
# OPENAI_MODEL=gpt-5.4-nano

# Chat system prompt overrides (in priority order):
#   1. CHAT_SYSTEM_PROMPT — inline string, highest priority
#   2. CHAT_SYSTEM_PROMPT_PATH — absolute path to a .md file
#   3. (default) src/modules/chat/prompts/expert-persona-system.md, bundled with the build
# CHAT_SYSTEM_PROMPT=
# CHAT_SYSTEM_PROMPT_PATH=

# Chat rate limiting (per user). Defaults: 20 requests / 60_000 ms.
# CHAT_RATE_LIMIT_TTL=60000
# CHAT_RATE_LIMIT_MAX=20
