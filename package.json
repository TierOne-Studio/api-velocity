{
  "name": "nest-typescript-starter",
  "private": true,
  "version": "1.0.0",
  "description": "Nest TypeScript starter repository",
  "license": "MIT",
  "scripts": {
    "build": "nest build && npm run copy:assets && npm run build:widget && npm run verify:build",
    "build:widget": "node scripts/build-widget.mjs",
    "verify:build": "node scripts/verify-build.mjs",
    "typecheck:widget": "tsc --noEmit -p tsconfig.widget.json",
    "test:e2e:widget": "playwright test --config e2e/playwright.config.ts",
    "copy:assets": "node -e \"const{mkdirSync,readdirSync,copyFileSync}=require('fs');const{join}=require('path');const src='src/modules/chat/prompts',dst='dist/modules/chat/prompts';mkdirSync(dst,{recursive:true});for(const f of readdirSync(src))if(f.endsWith('.md'))copyFileSync(join(src,f),join(dst,f));console.log('[copy:assets] copied chat prompts to '+dst);\"",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "node --experimental-vm-modules node_modules/.bin/jest --coverage",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/jest/bin/jest --runInBand",
    "test:e2e": "node --experimental-vm-modules node_modules/.bin/jest --config ./test/jest-e2e.json --runInBand",
    "test:smoke": "node --experimental-vm-modules node_modules/.bin/jest --testPathPattern=\"\\.smoke\\.spec\\.ts$\" --runInBand --testPathIgnorePatterns=\"\""
  },
  "engines": {
    "npm": ">=10.0.0",
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@airweave/sdk": "^0.9.60",
    "@anthropic-ai/sdk": "^0.104.2",
    "@aws-sdk/client-s3": "^3.1061.0",
    "@intellectronica/ruler": "0.3.40",
    "@langchain/classic": "1.0.27",
    "@langchain/core": "^1.1.39",
    "@langchain/openai": "^1.4.2",
    "@langchain/textsplitters": "^1.0.1",
    "@nestjs/common": "^11.0.17",
    "@nestjs/core": "^11.0.1",
    "@nestjs/graphql": "^13.3.0",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "^11.0.0",
    "@nestjs/websockets": "^11.1.19",
    "@qdrant/js-client-rest": "^1.18.0",
    "@thallesp/nestjs-better-auth": "^2.2.0",
    "better-auth": "^1.4.3",
    "better-sqlite3": "^12.4.6",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "graphql": "^16.13.2",
    "langchain": "1.3.0",
    "mammoth": "^1.12.0",
    "openai": "^6.33.0",
    "pg": "^8.16.3",
    "pg-boss": "^12.18.2",
    "reflect-metadata": "^0.2.2",
    "resend": "^6.5.2",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.28",
    "unpdf": "^1.6.2"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@playwright/test": "^1.61.0",
    "@swc/cli": "^0.6.0",
    "@swc/core": "^1.10.8",
    "@testcontainers/postgresql": "^11.14.0",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.10.7",
    "@types/pg": "^8.15.6",
    "@types/supertest": "^6.0.2",
    "esbuild": "^0.28.1",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.3",
    "globals": "^15.14.0",
    "jest": "^29.7.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.48.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts",
      "mjs"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "testPathIgnorePatterns": [
      "\\.smoke\\.spec\\.ts$"
    ],
    "transform": {
      "^.+\\.(t|j)s$": [
        "ts-jest",
        {
          "useESM": true,
          "tsconfig": {
            "module": "ESNext"
          }
        }
      ]
    },
    "extensionsToTreatAsEsm": [
      ".ts"
    ],
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    },
    "transformIgnorePatterns": [
      "node_modules/(?!(better-auth|@better-auth|better-call|@thallesp)/)"
    ],
    "collectCoverageFrom": [
      "**/*.(t|j)s",
      "!**/*.spec.ts",
      "!**/*.e2e-spec.ts",
      "!**/main.ts",
      "!**/*.module.ts",
      "!**/auth.ts",
      "!**/permissions.ts",
      "!**/public-chat/widget/ui.ts",
      "!**/public-chat/widget/stream-transport.ts",
      "!**/public-chat/widget/widget.entry.ts",
      "!**/public-chat/widget/markdown-render.ts"
    ],
    "coverageReporters": [
      "text",
      "text-summary"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "setupFiles": [
      "<rootDir>/../test/setup.ts"
    ]
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@swc/core"
    ]
  }
}
